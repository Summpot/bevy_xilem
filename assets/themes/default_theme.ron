(
  rules: [
    (
      selector: Type("UiRoot"),
      setter: (
        colors: (
          bg: Hex("#1B1B1B"),
        ),
      ),
    ),
    (
      selector: Type("UiFlexColumn"),
      setter: (
        layout: (
          gap: 8.0,
        ),
      ),
    ),
    (
